---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="min-h-screen flex items-center justify-center py-24">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <div class="text-6xl mb-6">🎉</div>
      <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-6">We'll be in touch!</h1>
      <p class="text-lg sm:text-xl text-muted-foreground mb-8 leading-relaxed">Thanks for reaching out. Jacques or Sharon will call you back shortly to discuss your lessons.</p>
      <p class="text-muted-foreground mb-10">
        Can't wait? Call us directly.<br /><br />
        <a href="tel:+27829502858" title="Call Jacques at Hey! Another Driving School" class="font-semibold text-foreground hover:underline">Jacques — 082 950 2858</a>
        &nbsp;·&nbsp;
        <a href="tel:+27711833500" title="Call Sharon at Hey! Another Driving School" class="font-semibold text-foreground hover:underline">Sharon — 071 183 3500</a>
      </p>
      <a href="/" title="Back to Hey! Another Driving School homepage" class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-primary-foreground font-medium hover:opacity-90 transition-opacity">Back to home</a>
    </div>
  </section>
</Layout>