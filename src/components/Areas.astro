---
import { areas } from "@/content/content";
---

<section id="areas" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
        {areas.heading}
      </h2>
      <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
        {areas.subheading}
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      {areas.locations.map((location) => (
        <span class="px-4 py-2 rounded-full border border-border bg-background text-foreground font-medium text-sm hover:border-primary hover:text-primary transition-colors">
          {location}
        </span>
      ))}
    </div>
  </div>
</section>